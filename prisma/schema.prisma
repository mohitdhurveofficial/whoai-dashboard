generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String @id @default(cuid())
  name            String?
  email           String @unique
  password        String
  role            String @default("ADMIN")

  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Organization {
  id        String @id @default(cuid())
  name      String

  users     User[]

  createdAt DateTime @default(now())
}

model AIWorker {
  id              String @id @default(cuid())
  workspaceId     String

  name            String
  role            String
  department      String?
  owner           String?
  description     String?

  status          String
  riskScore       Int?
  riskLevel       String?
  confidenceScore Int?

  decisions       Decision[]

  createdAt DateTime @default(now())
}

model Policy {
  id                 String @id @default(cuid())
  workspaceId        String

  name               String
  description        String?
  category           String?

  status             String
  enforcementMode    String

  version            Int @default(1)
  assignedAgentCount Int @default(0)

  createdAt DateTime @default(now())
}

model Decision {
  id                String @id @default(cuid())
  workspaceId       String

  aiWorkerId        String
  aiWorker          AIWorker @relation(fields: [aiWorkerId], references: [id])

  title             String
  description       String?

  riskScore         Int
  riskLevel         String

  confidenceScore   Int

  status            String

  policiesApplied   String[]

  createdAt         DateTime @default(now())

  approvals         Approval[]
}

model Approval {
  id          String @id @default(cuid())

  workspaceId String

  decisionId  String
  decision    Decision @relation(fields: [decisionId], references: [id])

  reviewerId  String

  status      String

  comment     String?

  createdAt   DateTime @default(now())
}